# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT Configuration
JWT_SECRET=your_secure_random_secret_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=7000
NODE_ENV=development
HOSTNAME=localhost

# SMS / OTP Mode
# USE_REAL_SMS=true  → Send real OTP via SMS; user enters OTP received on phone
# USE_REAL_SMS=false → Mock mode; use OTP 1234 for login/signup (no SMS sent)
USE_REAL_SMS=false

# Optional: SMS Provider (when USE_REAL_SMS=true)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL(s) for CORS — production: comma-separated if you have several domains
# (e.g. https://app.example.com,https://www.example.com). Dev: not required; server reflects Origin.
FRONTEND_URL=http://localhost:5173

# Optional: Admin Secret for protected signup
ADMIN_SECRET_KEY=your_admin_secret_key

# Redis (optional — Bull queues, route cache, location throttle, idempotency)
# Set REDIS_DISABLED=true to run without Redis: no Bull workers; use orderAutoCancelJob + MongoDB.
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DISABLED=false
# REDIS_ERROR_LOG_INTERVAL_MS=60000

# Google Maps — server-side Directions + Geocoding API (routes, seller address lookup, etc.)
# Create a key in Google Cloud → APIs & Services → Credentials. Enable "Directions API" and "Geocoding API".
# Billing must be enabled on the project. Restrict key by IP (server) in production, not by HTTP referrer.
# Browser key in frontend/.env is VITE_GOOGLE_MAPS_API_KEY — copy the same value here for server geocoding.
GOOGLE_MAPS_API_KEY=
# Optional alias (read if GOOGLE_MAPS_API_KEY is empty):
VITE_GOOGLE_MAPS_API_KEY=

# Delivery broadcast (seller accept → riders in service radius)
# DELIVERY_BROADCAST_REQUIRE_VERIFIED=true  → only isVerified riders (stricter)
# DELIVERY_BROADCAST_HAVERSINE_LIMIT=2000    → max docs scanned if $near returns none

# Hub-first order orchestration (SOP mode)
# true  -> customer order is routed to hub workflow first
# false -> existing seller-first workflow remains active
HUB_FIRST_ORDER_ROUTING=false
# SLA target hours for hub fulfillment
HUB_SLA_HOURS=3
# Default logical hub id for orchestration
DEFAULT_HUB_ID=MAIN_HUB

# Delivery timeout (v2 workflow) — cancels order if no rider accepts within this time
# Set to 10–15 minutes in production (milliseconds)
DEFAULT_DELIVERY_TIMEOUT_MS=900000
